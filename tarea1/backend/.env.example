# Azure AI Foundry Configuration
# ================================
# Obtén estos valores desde el Azure Portal:
# 1. Connection String: Portal → Tu Recurso AI → Settings → Endpoints and Keys → Copy "Connection String"
# 2. Deployment Name: El nombre del modelo desplegado (ej. gpt-4o, gpt-4-turbo)

AZURE_AI_PROJECT_CONNECTION_STRING=<subscription-id>;<resource-group>;<project-name>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Server Configuration
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
